%%{init: {"theme": "base", "flowchart": {"curve": "basis"}} }%%
flowchart TD
  style A fill:#f9f,stroke:#333,stroke-width:1px
  A["Code Commit"] --> B["Pipeline Trigger"]
  B --> C["SAST Scan"]
  C --> D["SCA Scan"]
  D --> E["Build Artifact"]
  E --> F["Container Build"]
  F --> G["Container Scan"]
  G --> H["IaC Scan"]
  H --> I["Policy Check"]
  I --> J{"Approval Gate"}
  J -->|Approved| K["Deploy via ArgoCD"]
  J -->|Rejected| L["Block / Fix Issues"]

  classDef step fill:#f8f8f8,stroke:#333,stroke-width:1px;
  class A,B,C,D,E,F,G,H,I,K,L step;
